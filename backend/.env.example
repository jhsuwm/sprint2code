# Gemini AI Configuration (Required for AI code generation)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# GitHub Configuration (Required for creating branches and PRs)
GITHUB_TOKEN=your_github_personal_access_token_here

# JIRA Configuration (Required for story management)
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your_email@example.com
JIRA_API_TOKEN=your_jira_api_token_here

# JWT Authentication (Required for dashboard login)
JWT_SECRET_KEY=your_secure_random_secret_key_here

# Optional: Backend Port
PORT=8000

# Auto-Fix Configuration
# Enable parallel auto-fix with multiple workers (default: true)
# Set to 'false' for sequential processing (legacy mode)
PARALLEL_AUTOFIX=true

# Number of parallel auto-fix workers (default: 3)
# Optimal: 3-4 workers for best balance of speed vs API rate limits
# Higher values (5-10) hit Gemini API rate limits with diminishing returns
# Lower values (1-2) are slower. Each worker processes one file at a time.
AUTO_FIX_WORKERS=3

# Maximum number of auto-fix cycle attempts per individual file before skipping it.
# Prevents long runs caused by repeatedly retrying stubborn files across cycles.
AUTO_FIX_MAX_FILE_CYCLES=12

# Maximum number of files to process in a single auto-fix cycle.
AUTO_FIX_MAX_FILES_PER_CYCLE=12

# Timeout (seconds) for one auto-fix cycle before moving on.
AUTO_FIX_CYCLE_TIMEOUT_SEC=300

# Hard cap on total auto-fix cycles per run.
AUTO_FIX_MAX_CYCLES=12

# Hard cap on total auto-fix runtime (minutes) per run.
AUTO_FIX_MAX_RUNTIME_MINUTES=25
